{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "TradeDemo.Api.Services": "Information"
    }
  },
  "TickJournal": {
    "Enabled": false,
    "Provider": "None",
    "BatchSize": 4096,
    "FlushIntervalMilliseconds": 250,
    "FailFast": false,
    "Local": {
      "DirectoryPath": "data/tick-journal",
      "MaxSegmentBytes": 134217728,
      "FsyncOnFlush": false
    },
    "Blob": {
      "ContainerName": "tick-journal",
      "Prefix": "ticks"
    },
    "EventHubs": {
      "EventHubName": "ticks",
      "ConsumerGroup": "$Default",
      "PartitionKeyStrategy": "Symbol"
    }
  },
  "AllowedHosts": "*"
}
