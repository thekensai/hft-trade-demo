<Window x:Class="TradeDemo.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Trade Signal Terminal (WPF)"
        Height="950"
        Width="1700"
        MinHeight="780"
        MinWidth="1320"
        Background="#071427">
    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#071427"/>
        <SolidColorBrush x:Key="BgPanel" Color="#0d1c36"/>
        <SolidColorBrush x:Key="BgPanelAlt" Color="#122444"/>
        <SolidColorBrush x:Key="BorderBrushPanel" Color="#1f345c"/>
        <SolidColorBrush x:Key="CyanBrush" Color="#00c9ff"/>
        <SolidColorBrush x:Key="GreenBrush" Color="#1ecb8b"/>
        <SolidColorBrush x:Key="RedBrush" Color="#ff5e73"/>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#d6e2ff"/>
        </Style>
        <Style TargetType="Border" x:Key="PanelStyle">
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Background" Value="{StaticResource BgPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushPanel}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="4"/>
        </Style>

        <Style x:Key="TerminalGridBase" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HeadersVisibility" Value="None"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Foreground" Value="#d7e7ff"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>

        <Style x:Key="TerminalCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Foreground" Value="#d7e7ff"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelStyle}" Background="#0a1731">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="◈ TRADE TERMINAL" FontFamily="Consolas" FontWeight="Bold" FontSize="26" Foreground="{StaticResource CyanBrush}"/>
                    <TextBlock Text="  ● " Margin="18,0,0,0" FontSize="18" Foreground="{Binding ConnectionStatusBrush}"/>
                    <TextBlock Text="{Binding ConnectionStatusText}" FontFamily="Consolas" FontWeight="SemiBold" FontSize="16" Foreground="#9fb3d8"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="Backend:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#8aa0c7"/>
                    <TextBox Width="520" Text="{Binding BackendBaseUrl, UpdateSourceTrigger=PropertyChanged}" Background="#091731" Foreground="#d6e2ff" BorderBrush="#2e4d7f" BorderThickness="1" Padding="8,5" FontFamily="Consolas"/>
                    <Button Content="Connect" Margin="10,0,0,0" Padding="14,6" Background="#113862" Foreground="#dff3ff" BorderBrush="#2e5f95" Click="ConnectButton_Click"/>
                    <Button Content="Disconnect" Margin="6,0,0,0" Padding="14,6" Background="#3b1f31" Foreground="#ffd7df" BorderBrush="#75445a" Click="DisconnectButton_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#13345e" BorderBrush="#2b5a9d" BorderThickness="1" CornerRadius="4" Margin="0,0,6,0" Padding="10,4">
                        <TextBlock Text="{Binding ClientMsgPerSec, StringFormat={}{0} msg/s}" FontFamily="Consolas" Foreground="{StaticResource CyanBrush}" FontSize="16"/>
                    </Border>
                    <Border Background="#13345e" BorderBrush="#2b5a9d" BorderThickness="1" CornerRadius="4" Margin="0,0,6,0" Padding="10,4">
                        <TextBlock Text="Q: {Binding QueueDepth}" FontFamily="Consolas" Foreground="{StaticResource CyanBrush}" FontSize="16"/>
                    </Border>
                    <TextBlock Text="{Binding ClockText}" FontFamily="Consolas" FontSize="20" Foreground="#95add2" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource PanelStyle}" Padding="6" Background="#0b1b36">
            <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding TickerItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                <TextBlock Text="{Binding Symbol}" FontWeight="Bold" FontFamily="Consolas" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding PriceText}" FontFamily="Consolas" Foreground="{Binding ChangeBrush}" Margin="0,0,6,0"/>
                                <TextBlock Text="{Binding ChangePercentText}" FontFamily="Consolas" Foreground="{Binding ChangeBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.34*"/>
                <ColumnDefinition Width="0.42*"/>
                <ColumnDefinition Width="0.24*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="LIVE PRICES" FontFamily="Consolas" FontSize="17" FontWeight="Bold" Margin="0,0,0,10" Foreground="#7c95bf"/>
                    <DataGrid ItemsSource="{Binding PriceRows}" Style="{StaticResource TerminalGridBase}" FontSize="22" FontFamily="Consolas" RowHeight="54" CellStyle="{StaticResource TerminalCellStyle}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{Binding RowBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{Binding ChangeBrush}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Symbol}" Width="1.1*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#e6efff"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding PriceText}" Width="1*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding ChangeBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding ChangePercentText}" Width="0.9*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding ChangeBrush}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding Exchange}" Width="0.7*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#88a2ca"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PanelStyle}">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SIGNAL FEED" FontFamily="Consolas" FontSize="17" FontWeight="Bold" Foreground="#7c95bf"/>
                        <Border Grid.Column="1" Background="#3778e6" CornerRadius="8" Padding="8,1">
                            <TextBlock Text="{Binding FeedCount}" Foreground="White" FontFamily="Consolas" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                    <DataGrid ItemsSource="{Binding FeedRows}" Style="{StaticResource TerminalGridBase}" FontSize="18" FontFamily="Consolas" RowHeight="38" CellStyle="{StaticResource TerminalCellStyle}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{Binding RowBackgroundBrush}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding TimeText}" Width="0.9*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#8ba4cd"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding Symbol}" Width="1*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#dce8ff"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding PriceText}" Width="1*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding PriceBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding VolumeText}" Width="0.8*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#91a9d2"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Binding="{Binding Direction}" Width="0.8*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding DirectionBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.62*"/>
                    <RowDefinition Height="0.38*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelStyle}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="ORDER FLOW" FontFamily="Consolas" FontSize="17" FontWeight="Bold" Margin="0,0,0,10" Foreground="#7c95bf"/>
                        <ItemsControl ItemsSource="{Binding OrderFlowRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.58*"/>
                                            <ColumnDefinition Width="0.32*"/>
                                            <ColumnDefinition Width="0.10*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Symbol}" VerticalAlignment="Center" FontFamily="Consolas" FontWeight="SemiBold"/>
                                        <Grid Grid.Column="1" Height="18" VerticalAlignment="Center" Background="#101f38">
                                            <Rectangle Fill="#15a57e" HorizontalAlignment="Left" Width="{Binding BuyPixels}"/>
                                            <Rectangle Fill="#c8444f" HorizontalAlignment="Right" Width="{Binding SellPixels}"/>
                                        </Grid>
                                        <TextBlock Grid.Column="2" Text="{Binding BuyRatioText}" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" Foreground="#8ea5cb"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource PanelStyle}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="THROUGHPUT STATS" FontFamily="Consolas" FontSize="17" FontWeight="Bold" Margin="0,0,0,10" Foreground="#7c95bf"/>
                        <UniformGrid Rows="2" Columns="2">
                            <StackPanel Margin="8">
                                <TextBlock Text="PROCESSED" Foreground="#6e88b4" FontFamily="Consolas"/>
                                <TextBlock Text="{Binding ProcessedCount}" Foreground="{StaticResource CyanBrush}" FontFamily="Consolas" FontSize="34" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="8">
                                <TextBlock Text="DROPPED" Foreground="#6e88b4" FontFamily="Consolas"/>
                                <TextBlock Text="{Binding DroppedCount}" Foreground="{StaticResource RedBrush}" FontFamily="Consolas" FontSize="34" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="8">
                                <TextBlock Text="QUEUE DEPTH" Foreground="#6e88b4" FontFamily="Consolas"/>
                                <TextBlock Text="{Binding QueueDepth}" Foreground="#9fd0ff" FontFamily="Consolas" FontSize="34" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Margin="8">
                                <TextBlock Text="MSG/SEC (CLIENT)" Foreground="#6e88b4" FontFamily="Consolas"/>
                                <TextBlock Text="{Binding ClientMsgPerSec}" Foreground="{StaticResource GreenBrush}" FontFamily="Consolas" FontSize="34" FontWeight="Bold"/>
                            </StackPanel>
                        </UniformGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
